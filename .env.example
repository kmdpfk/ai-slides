# Copy to .env.local and replace with the SHA-256 hash of your chosen password.
# Generate the hash (PowerShell):
#   $pw = Read-Host -AsSecureString "Password"
#   $bstr = [Runtime.InteropServices.Marshal]::SecureStringToBSTR($pw)
#   $plain = [Runtime.InteropServices.Marshal]::PtrToStringAuto($bstr)
#   [BitConverter]::ToString(
#     [Security.Cryptography.SHA256]::Create().ComputeHash(
#       [Text.Encoding]::UTF8.GetBytes($plain)
#     )
#   ).Replace('-', '').ToLower()
#
# Or in Node:
#   node -e "console.log(require('crypto').createHash('sha256').update(process.argv[1]).digest('hex'))" "your-password"
#
# Leave this variable unset to disable the gate entirely (open access).
VITE_APP_PASSWORD_HASH="74e6c40f1038e83f18a9938dd1af0a2d691f3af4dba841da66e1d65cf237a6cf"
